meta {
  name: Process Payment
  type: http
  seq: 1
}

post {
  url: {{paymentUrl}}/api/v1/payments
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "reservationId": "{{reservationId}}",
    "customerId": "{{customerId}}",
    "amount": 180.00,
    "currency": "USD"
  }
}
